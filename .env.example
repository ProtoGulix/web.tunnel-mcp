# URL de base de l'API Tunnel
# Docker interne : http://tunnel-api:8000
# Local dev      : http://localhost:8000
TUNNEL_API_BASE_URL=http://localhost:8000

# Token Bearer d'un compte CONSULTANT dédié (jamais un compte terrain)
# Générer via POST /auth/login avec mcp-consultant@frezille.fr
TUNNEL_API_TOKEN=

# Transport MCP : stdio (dev) ou sse (production)
MCP_TRANSPORT=stdio

# Port SSE (production uniquement)
MCP_SSE_PORT=8001
